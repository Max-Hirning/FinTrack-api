{
  "private": true,
  "license": "MIT",
  "version": "1.0.0",
  "name": "fintrack-api",
  "jest": {
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "rootDir": "src",
    "moduleNameMapper": {
      "^@configs/(.*)$": "<rootDir>/../src/configs/$1",
      "^@authModule/(.*)$": "<rootDir>/../src/modules/auth/$1",
      "^@cardModule/(.*)$": "<rootDir>/../src/modules/card/$1",
      "^@userModule/(.*)$": "<rootDir>/../src/modules/user/$1",
      "^@imageModule/(.*)$": "<rootDir>/../src/modules/image/$1",
      "^@commonModule/(.*)$": "<rootDir>/../src/modules/common/$1",
      "^@balanceModule/(.*)$": "<rootDir>/../src/modules/balance/$1",
      "^@categoryModule/(.*)$": "<rootDir>/../src/modules/category/$1",
      "^@firebaseModule/(.*)$": "<rootDir>/../src/modules/firebase/$1",
      "^@transactionModule/(.*)$": "<rootDir>/../src/modules/transaction/$1",
      "^@balanceHistoryModule/(.*)$": "<rootDir>/../src/modules/balance-history/$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ],
    "testEnvironment": "node",
    "testRegex": ".*\\.spec\\.ts$",
    "coverageDirectory": "../coverage"
  },
  "author": {
    "name": "Max-Hirning",
    "url": "https://github.com/Max-Hirning"
  },
  "scripts": {
    "build": "nest build",
    "prepare": "husky install",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "start": "nest start",
    "start:prod": "node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "ts": "tsc --project tsconfig.json",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Max-Hirning/FinTrack-api"
  },
  "dependencies": {
    "@nestjs-modules/mailer": "^1.11.2",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "*",
    "@nestjs/mongoose": "^10.0.4",
    "@nestjs/platform-express": "^10.0.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cloudinary": "^2.0.3",
    "mongoose": "^8.1.1",
    "multer": "^1.4.5-lts.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.3.1",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.57.0",
    "husky": "^8.0.0",
    "jest": "^29.5.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  }
}
